// This configuration is merged with the default vicinae configuration file, which you can obtain by running the `vicinae config default` command.
// Every item defined in this file takes precedence over the values defined in the default config or any other imported file.
//
// You can make manual edits to this file, however you should keep in mind that this file may be written to by vicinae when a configuration change is made through the GUI.
// When that happens, any custom comments or formatting will be lost.
//
// If you want to maintain a configuration file with your own comments and formatting, you should create a separate file and add it to the 'imports' array.
//
// Learn more about configuration at https://docs.vicinae.com/config

{
   "$schema": "https://vicinae.com/schemas/config.json",
   "close_on_focus_loss": true,
   "pop_to_root_on_close": true,
   "activate_on_single_click": true,
   "font": {
      "normal": {
         "family": "FiraMono Nerd Font",
         "size": 10
      }
   },
   "theme": {
      "dark": {
         "name": "noctalia",
         "icon_theme": "Papirus"
      }
   },
   "telemetry": {
      "system_info": false
   },
   "launcher_window": {
      "opacity": 0.9,
      "client_side_decorations": {
         "enabled": true
      }
   },
   "keybinds": {
      "toggle-action-panel": "F12"
   },
   "favorites": [
      "wm:switch-windows",
      "system:run",
      "clipboard:history",
      "applications:kitty",
      "applications:com.shellyorg.shelly",
      "applications:systemsettings"
   ],
   "providers": {
      "@rithvikvibhu/store.vicinae.arch-packages": {
         "enabled": false
      },
      "applications": {
         "preferences": {
            "defaultAction": "launch",
            "paths": [
               "/home/milo_the_moth/.local/share/applications",
               "/home/milo_the_moth/.local/share/flatpak/exports/share/applications",
               "/var/lib/flatpak/exports/share/applications",
               "/usr/local/share/applications",
               "/usr/share/applications"
            ]
         },
         "entrypoints": {
            "nemo": {
               "alias": "Nemo",
               "enabled": true
            },
            "org.gnome.Nautilus": {
               "enabled": false
            }
         }
      },
      "browser-extension": {
         "enabled": false
      },
      "calculator": {
         "enabled": false
      },
      "clipboard": {
         "enabled": true,
         "preferences": {
            "encryption": false,
            "eraseOnStartup": true,
            "ignorePasswords": false,
            "monitoring": true
         },
         "entrypoints": {
            "clear": {
               "enabled": false
            },
            "clear-history": {
               "enabled": true
            },
            "history": {
               "enabled": true
            }
         }
      },
      "core": {
         "enabled": true,
         "entrypoints": {
            "documentation": {
               "enabled": false
            },
            "forget-telemetry": {
               "enabled": false
            },
            "inspect-local-storage": {
               "enabled": false
            },
            "keybind-settings": {
               "enabled": false
            },
            "list-extensions": {
               "enabled": false
            },
            "manage-fallback": {
               "enabled": false
            },
            "oauth-token-store": {
               "enabled": false
            },
            "open-config-file": {
               "enabled": true
            },
            "open-default-config": {
               "enabled": false
            },
            "prune-memory": {
               "enabled": true
            },
            "refresh-apps": {
               "enabled": false
            },
            "reload-scripts": {
               "enabled": false
            },
            "report-bug": {
               "enabled": false
            },
            "search-builtin-icons": {
               "enabled": false
            },
            "search-emojis": {
               "enabled": false
            },
            "sponsor": {
               "enabled": false
            },
            "store": {
               "enabled": true
            }
         }
      },
      "developer": {
         "enabled": false,
         "entrypoints": {
            "create": {
               "enabled": false
            }
         }
      },
      "files": {
         "enabled": false,
         "preferences": {
            "autoIndexing": false,
            "excludedPaths": "",
            "paths": "/home/milo_the_moth",
            "watcherPaths": ""
         },
         "entrypoints": {
            "rebuild-index": {
               "enabled": false
            },
            "search": {
               "enabled": false
            }
         }
      },
      "font": {
         "enabled": false
      },
      "manage-shortcuts": {
         "enabled": false
      },
      "power": {
         "enabled": true,
         "entrypoints": {
            "hibernate": {
               "enabled": false
            },
            "soft-reboot": {
               "enabled": false
            }
         }
      },
      "raycast-compat": {
         "enabled": false,
         "entrypoints": {
            "store": {
               "enabled": true
            }
         }
      },
      "scripts": {
         "enabled": false
      },
      "shortcuts": {
         "enabled": false
      },
      "theme": {
         "enabled": false
      },
      "wm": {
         "enabled": true
      }
   }
}